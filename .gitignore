env/
.env
__pycache__/

# Training data (~80MB) - regenerable via the Cricsheet download commands
# (see chat history), but too large/binary to be worth versioning in git.
data/

# NOTE: models/saved/*.pkl is deliberately NOT ignored, even though it's
# a build artifact - Render deploys straight from this repo and won't have
# data/ available to retrain from, so the trained models need to be
# committed for the deployed API to actually serve predictions.

# SQLite database - local runtime state, not source.
cricket_iq.db

# stray leftover files from an earlier data-extraction attempt
data/tests/*.csv
